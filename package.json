{
  "name": "ruflo-bot-tester",
  "version": "1.0.0",
  "description": "Multi-agent chatbot testing framework powered by Ruflo — evaluate AI bots for accuracy, safety, relevance and hallucination",
  "type": "module",
  "bin": {
    "rbt": "./bin/rbt.js"
  },
  "scripts": {
    "test": "node bin/rbt.js run examples/basic.yaml",
    "example:safety": "node bin/rbt.js run examples/safety.yaml",
    "example:multiturn": "node bin/rbt.js run examples/multiturn.yaml"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "chalk": "^5.3.0",
    "@anthropic-ai/sdk": "^0.106.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["bot-testing", "llm", "ai", "ruflo", "chatbot", "evaluation"],
  "license": "MIT"
}
